cd ~/Desktop/xokai@import "tailwindcss"; nano src/app/globals.css :root { grep -n "1A6B4A\|green\|#0F4A32" 
~/Desktop/xokai/src/app/\(auth\)/login/page.tsx --background: #ffffff;
  --foreground: #171717; }

@theme inline { grep -n "1A6B4A\|green\|#0F4A32" ~/Desktop/xokai/src/app/\(auth\)/login/page.tsx 
--color-background: var(--background); grep -n "1A6B4A\|6B4A\|green" 
~/Desktop/xokai/src/app/\(auth\)/login/page.tsx --color-foreground: var(--foreground); grep -n "style=" 
~/Desktop/xokai/src/app/\(auth\)/login/page.tsx --font-sans: var(--font-geist-sans); cat 
~/Desktop/xokai/src/app/\(auth\)/login/page.tsx | grep -n "Color\|color\|bg-\["  --font-mono: 
var(--font-geist-mono); } cd ~/Desktop/xokai @media (prefers-color-scheme: dark) { bash setup.sh :root { npm 
run dev --background: #0a0a0a; cd ~/Desktop/xokai --foreground: #ededed; bash setup.sh } } npm run dev body {
  background: var(--background); color: var(--foreground); font-family: Arial, Helvetica, sans-serif;
}
