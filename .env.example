# ============================================================
# XOKAI — Variables de entorno
# Copiar este archivo como .env.local y completar los valores.
# NUNCA subir .env.local al repositorio.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Obtenidas en: https://app.supabase.com → Settings → API

# URL pública del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave pública anónima (segura para exponer al cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de servicio (SOLO servidor — NUNCA en NEXT_PUBLIC_*)
# Usada para operaciones admin (crear usuarios, bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Sentry — Error tracking ──────────────────────────────────
# Obtenidas en: https://sentry.io → Settings → Projects → [proyecto] → Client Keys

# DSN del proyecto de Sentry (seguro para exponer al cliente)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx

# Entorno Sentry: development | preview | production
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Token de autenticación Sentry para subir source maps (solo CI/CD)
# Obtenido en: https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=sntrys_...

# Organización y proyecto en Sentry (para source maps en CI)
SENTRY_ORG=xokai
SENTRY_PROJECT=xokai-web

# ── Stripe — Pagos ───────────────────────────────────────────
# Obtenidas en: https://dashboard.stripe.com → Developers → API keys

# Clave pública de Stripe (segura para el cliente)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Clave secreta de Stripe (SOLO servidor — NUNCA en NEXT_PUBLIC_*)
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret de Stripe (para verificar firmas de eventos)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ──────────────────────────────────────────────────────

# URL base de la aplicación (sin trailing slash)
# Ejemplo desarrollo: http://localhost:3000
# Ejemplo producción: https://app.xokai.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Opcionales / Futuro ──────────────────────────────────────

# Resend API key para emails transaccionales
# Obtenida en: https://resend.com → API Keys
# RESEND_API_KEY=re_...

# Twilio para SMS / WhatsApp (comunicados)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
